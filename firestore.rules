rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() { return request.auth != null; }
    function role() {
      return isSignedIn() && exists(/databases/$(database)/documents/kioskUsers/$(request.auth.uid))
        ? get(/databases/$(database)/documents/kioskUsers/$(request.auth.uid)).data.role
        : null;
    }
    function isManager() { return role() in ['super_admin', 'manager', 'Super Admin']; }
    function isDelivery() { return role() in ['super_admin', 'manager', 'delivery', 'Super Admin']; }

    // Menu & categories: public read, stock-only public update, admin full write
    match /kioskMenu/{docId} {
      allow read: if true;
      // Public updates restricted to stock fields only (for kiosk order stock decrement)
      allow update: if isManager()
        || (request.resource.data.diff(resource.data).affectedKeys().hasOnly(["stock", "inStock", "updatedAt"]));
      allow create, delete: if isManager();
    }
    match /kioskCategories/{docId} {
      allow read: if true;
      allow write: if isManager();
    }

    // Orders: public create (customers place from kiosk), authenticated read/update
    match /kioskOrders/{docId} {
      allow read: if isSignedIn();
      allow create: if true;
      allow update: if isManager() || isDelivery();
      allow delete: if false;
    }

    // Kiosk users: public create (self-registration), authenticated read/update
    match /kioskUsers/{userId} {
      allow read: if isSignedIn();
      allow create: if true;
      // Self-update allowed but cannot change own role; managers can change anything
      allow update: if isManager()
        || (isSignedIn() && request.auth.uid == userId
            && !request.resource.data.diff(resource.data).affectedKeys().hasAny(["role"]));
      allow delete: if isManager();
    }

    // Admin accounts: authenticated read (behind OperatorGate), admin-only write
    match /kioskAdmins/{docId} {
      allow read: if isSignedIn();
      allow write: if isManager();
    }

    // App config: public read, orderCounter needs public write for kiosk orders
    match /kioskConfig/orderCounter {
      allow read: if true;
      allow write: if true;
    }
    match /kioskConfig/{docId} {
      allow read: if true;
      allow write: if isManager();
    }

    // Inventory adjustments: authenticated read/write
    match /inventoryAdjustments/{docId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }

    // Audit logs: authenticated read, public create (kiosk orders log without auth)
    match /auditLogs/{docId} {
      allow read: if isSignedIn();
      allow create: if true;
      allow update, delete: if isManager();
    }

    // QuickBooks tokens: deny ALL client access.
    // Only Cloud Functions (firebase-admin SDK) can read/write — it bypasses rules.
    match /qbTokens/{docId} {
      allow read, write: if false;
    }

    // Deny everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
