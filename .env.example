# Firebase project configuration (required)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Dev-only: default admin password for seed data (not used in production)
# VITE_DEFAULT_ADMIN_PW=

# QuickBooks integration (set via `firebase functions:secrets:set` — NOT stored here)
# QB_CLIENT_ID=        → get from developer.intuit.com after app registration
# QB_CLIENT_SECRET=    → get from developer.intuit.com after app registration
# QB_REDIRECT_URI=     → your Cloud Function callback URL
# QB_ENVIRONMENT=      → "sandbox" or "production"
