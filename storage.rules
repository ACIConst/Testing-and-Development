rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    match /menu-images/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /barcode-images/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
